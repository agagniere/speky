{
  "name": "speky",
  "description": "Skills to best use Speky, the requirements and test specification manager.",
  "version": "0.4.0",
  "author": {
    "name": "Antoine Gagniere",
    "email": "antoine@gagniere.dev",
    "url": "https://github.com/agagniere"
  },
  "homepage": "https://agagniere.github.io/speky",
  "repository": "https://github.com/agagniere/speky",
  "license": "MIT",
  "keywords": [
    "specification",
    "requirements"
  ],
  "mcpServers": {
    "speky": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "speky-mcp",
        "${user_config.spec_folder}/${user_config.manifest_name}"
      ],
      "env": {
        "UV_CACHE_DIR": "${CLAUDE_PLUGIN_DATA}/uvcache",
        "UV_PROJECT": "${CLAUDE_PLUGIN_ROOT}"
      }
    },
    "speky-selfspec": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "speky-mcp",
        "specs/speky.yaml",
        "specs/mcp/mcp.toml"
      ],
      "env": {
        "UV_CACHE_DIR": "${CLAUDE_PLUGIN_DATA}/uvcache",
        "UV_WORKING_DIR": "${CLAUDE_PLUGIN_ROOT}"
      }
    }
  },
  "userConfig": {
    "spec_folder": {
      "title": "Specification folder",
      "description": "Where specification files are placed",
      "type": "directory",
      "default": "specs"
    },
    "manifest_name": {
      "title": "Manifest name",
      "description": "Filename of the main manifest of the repo's specification",
      "type": "file",
      "default": "spec.yaml"
    }
  }
}
