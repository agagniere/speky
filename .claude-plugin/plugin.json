{
  "name": "speky",
  "description": "Skills to best use Speky, the requirements and test specification manager.",
  "version": "0.4.0",
  "author": {
    "name": "Antoine Gagniere",
    "email": "antoine@gagniere.dev",
    "url": "https://github.com/agagniere"
  },
  "homepage": "https://agagniere.github.io/speky",
  "repository": "https://github.com/agagniere/speky",
  "license": "MIT",
  "keywords": [
    "specification",
    "requirements"
  ],
  "mcpServers": {
    "speky": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "speky-mcp",
        "specs/spec.yaml"
      ],
      "env": {
        "UV_CACHE_DIR": "${CLAUDE_PLUGIN_DATA}/uvcache",
        "UV_PROJECT": "${CLAUDE_PLUGIN_ROOT}"
      }
    },
    "speky-selfspec": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "speky-mcp",
        "specs/speky.yaml",
        "specs/mcp/mcp.toml"
      ],
      "env": {
        "UV_CACHE_DIR": "${CLAUDE_PLUGIN_DATA}/uvcache",
        "UV_WORKING_DIR": "${CLAUDE_PLUGIN_ROOT}"
      }
    }
  }
}
